{
  "name": "my-voice-skill",
  "version": "0.1.0",
  "description": "Claude Code skill that distills a user's language fingerprint and per-contact relational memory from exported chat history, so a runtime agent can reply on their behalf.",
  "type": "module",
  "private": true,
  "license": "MIT",
  "scripts": {
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "parse": "bun run src/cli/parse.ts",
    "parse-groups": "bun run src/cli/parse_groups.ts",
    "stats": "bun run src/cli/stats.ts",
    "filter": "bun run src/cli/filter.ts",
    "group-stats": "bun run src/cli/group_stats.ts",
    "group-signals": "bun run src/cli/group_signals.ts",
    "group-context": "bun run src/cli/group_context.ts"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.30.0",
    "@node-rs/jieba": "^2.0.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.6.0"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
